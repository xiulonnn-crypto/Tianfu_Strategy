#!/bin/bash
# Git pre-push hook: 推送 main 时自动把本地原始数据同步到 GitHub Secrets，
# 确保 CI (.github/workflows/compute.yml) 下一次执行 compute.py 使用最新数据。
#
# 安装方式：./scripts/install-hooks.sh
# 绕过方式：git push --no-verify

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

# git 按照 <local_ref> <local_sha> <remote_ref> <remote_sha> 逐行通过 stdin 传入
PUSH_TO_MAIN=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/main)
      PUSH_TO_MAIN=1
      break
      ;;
  esac
done

if [ "$PUSH_TO_MAIN" -eq 0 ]; then
  exit 0
fi

if [ ! -x "./sync-secrets.sh" ]; then
  echo "[pre-push] 跳过：未找到可执行的 ./sync-secrets.sh" >&2
  exit 0
fi

echo "[pre-push] 推送 main，开始同步原始数据到 GitHub Secrets..." >&2
if ! ./sync-secrets.sh; then
  echo "" >&2
  echo "[pre-push] ❌ Secrets 同步失败。" >&2
  echo "  - 请确认 gh CLI 已登录（gh auth status）" >&2
  echo "  - 或临时绕过：git push --no-verify" >&2
  exit 1
fi

echo "[pre-push] ✓ Secrets 已同步，继续推送。CI 将使用最新数据。" >&2
exit 0
